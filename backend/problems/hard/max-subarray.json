{
  "id": "max-subarray",
  "title": "Maximum Subarray Sum",
  "difficulty": "hard",
  "type": "algorithm",
  "description": "Read a line of space-separated integers. Print the largest sum of any contiguous non-empty subarray.",
  "examples": [
    {
      "input": "-2 1 -3 4 -1 2 1 -5 4",
      "output": "6"
    },
    {
      "input": "1 2 3 4",
      "output": "10"
    }
  ],
  "test_cases": [
    {
      "input": "-2 1 -3 4 -1 2 1 -5 4",
      "expected": "6"
    },
    {
      "input": "1 2 3 4",
      "expected": "10"
    },
    {
      "input": "-1 -2 -3",
      "expected": "-1"
    },
    {
      "input": "5 -2 3",
      "expected": "6"
    }
  ],
  "time_limit_seconds": 10
}