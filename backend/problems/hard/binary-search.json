{
  "id": "binary-search",
  "title": "Binary Search",
  "difficulty": "hard",
  "type": "algorithm",
  "description": "Line 1: a sorted (ascending) list of space-separated integers. Line 2: a target integer. Print the 0-based index of the target, or -1 if absent.",
  "examples": [
    {
      "input": "1 3 5 7 9\n5",
      "output": "2",
      "explanation": "5 is found at index 2 (0-based)."
    },
    {
      "input": "1 3 5 7 9\n6",
      "output": "-1",
      "explanation": "6 is not in the array, so the result is -1."
    }
  ],
  "test_cases": [
    {
      "input": "1 3 5 7 9\n5",
      "expected": "2"
    },
    {
      "input": "1 3 5 7 9\n6",
      "expected": "-1"
    },
    {
      "input": "2 4 6 8 10\n10",
      "expected": "4"
    },
    {
      "input": "1\n1",
      "expected": "0"
    }
  ],
  "time_limit_seconds": 10
}