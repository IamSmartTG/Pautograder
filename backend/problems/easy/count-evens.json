{
  "id": "count-evens",
  "title": "Count Even Numbers",
  "difficulty": "easy",
  "type": "algorithm",
  "description": "Read a line of space-separated integers and print how many are even (0 counts as even).",
  "test_cases": [
    {
      "input": "1 2 3 4 5 6",
      "expected": "3"
    },
    {
      "input": "1 3 5",
      "expected": "0"
    },
    {
      "input": "2 4 6 8",
      "expected": "4"
    },
    {
      "input": "0 -2 -3",
      "expected": "2"
    }
  ],
  "time_limit_seconds": 5
}